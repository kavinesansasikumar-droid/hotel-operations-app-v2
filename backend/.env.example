NODE_ENV=development
PORT=4000

# MongoDB Atlas or local:
MONGODB_URI=mongodb://localhost:27017/hotel-ops
JWT_SECRET=any_random_string_here_123

# Use a long random string in production (rotate if leaked)
JWT_SECRET=replace-with-at-least-16-characters
JWT_EXPIRES_IN=7d

# Comma-separated allowed origins (your Vercel URL + local)
CORS_ORIGIN=http://localhost:5173

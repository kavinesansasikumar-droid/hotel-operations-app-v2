# Public API base URL (no trailing slash). Leave empty in local dev to use Vite proxy to backend.
# Vercel production example:
# VITE_API_URL=https://your-api.onrender.com

VITE_API_URL=

# Optional: override proxy target when using `npm run dev` (see vite.config.ts)
# VITE_PROXY_TARGET=http://localhost:4000
